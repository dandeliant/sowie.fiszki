{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "id": "/",
  "name": "Sowie Fiszki — nauka angielskiego",
  "short_name": "Sowie Fiszki",
  "description": "Nauka angielskiego dla klas 1–8 i kursów: fiszki, gry, 17+ podręczników, generatory mówienia. Polska PWA edukacyjna.",
  "start_url": "/app",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui", "browser"],
  "background_color": "#1a1040",
  "theme_color": "#1a1040",
  "orientation": "any",
  "lang": "pl",
  "dir": "ltr",
  "categories": ["education", "kids", "books"],
  "icons": [
    {
      "src": "/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icon-maskable.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Otwórz aplikację",
      "short_name": "Aplikacja",
      "description": "Przejdź do nauki",
      "url": "/app",
      "icons": [{ "src": "/icon.svg", "sizes": "any", "type": "image/svg+xml" }]
    },
    {
      "name": "Panel nauczyciela",
      "short_name": "Nauczyciel",
      "description": "Klasy · Zestawy · Raporty",
      "url": "/teacher",
      "icons": [{ "src": "/icon.svg", "sizes": "any", "type": "image/svg+xml" }]
    },
    {
      "name": "Strona główna",
      "short_name": "Home",
      "description": "Marketing i informacje",
      "url": "/",
      "icons": [{ "src": "/icon.svg", "sizes": "any", "type": "image/svg+xml" }]
    }
  ],
  "prefer_related_applications": false
}
